# ShaktiScale AI — Backend environment variables (example)
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Application ---
APP_NAME=ShaktiScale AI
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# --- AI (OpenRouter) ---
# Optional. If unset, /explain and /proposal gracefully fall back to
# deterministic templates — the app never depends on this being set.
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Logging ---
LOG_LEVEL=INFO
